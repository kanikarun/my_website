{
  "editor.tabSize": 2,
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit"
  },
  "files.exclude": {
    "**/.git": true,
    "**/.svn": true,
    "**/.hg": true,
    "**/CVS": true,
    "**/.DS_Store": true,
    ".nyc_output": true,
    ".vscode": false,
    "coverage": true,
    "dist": true,
    "**/node_modules": true,
    "**/.next": true,
    "**/.swc": true,
    "**/.cache": true,
    "**/dist": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/backend": true,
    "**/dist": true
  },
  "cSpell.words": [
    "heroicons",
    "Navbars",
    "Nuqs",
    "oneworld",
    "Partneritem",
    "strapi",
    "Swiper",
    "tanstack"
  ],
  "editor.defaultFormatter": "esbenp.prettier-vscode"
}
